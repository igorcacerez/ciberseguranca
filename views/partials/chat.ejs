<div class="chat-window" id="chatWindow">
  <div class="terminal-titlebar">
    <span class="dot red"></span>
    <span class="dot yellow"></span>
    <span class="dot green"></span>
    <span class="terminal-title">SecureChat — simulacao corporativa</span>
    <span class="terminal-info">IA defensiva</span>
  </div>

  <div class="chat-brief">
    <div>
      <span class="chat-label">Empresa</span>
      <strong><%= missao.chat_empresa || 'Empresa simulada' %></strong>
    </div>
    <div>
      <span class="chat-label">Alvo do treinamento</span>
      <strong><%= missao.chat_funcionario || 'Funcionario simulado' %></strong>
    </div>
  </div>

  <div class="chat-messages" id="chatMessages">
    <div class="chat-message bot">
      <span class="chat-name"><%= missao.chat_funcionario || 'Funcionario' %></span>
      <p>Oi. Recebi sua mensagem pelo chat corporativo. Qual e o numero do chamado e o motivo do contato?</p>
    </div>
  </div>

  <form class="chat-input-row" id="chatForm">
    <input type="text" id="chatInput" class="chat-input" maxlength="800" autocomplete="off"
           placeholder="Digite uma abordagem de teste autorizada...">
    <button type="submit" class="chat-send">Enviar</button>
  </form>
</div>

<script>
(function() {
  const form = document.getElementById('chatForm');
  const input = document.getElementById('chatInput');
  const messages = document.getElementById('chatMessages');
  const missionId = <%= missao.id %>;

  function escHtml(s) {
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function addMessage(kind, name, text) {
    const el = document.createElement('div');
    el.className = 'chat-message ' + kind;
    el.innerHTML = `<span class="chat-name">${escHtml(name)}</span><p>${escHtml(text)}</p>`;
    messages.appendChild(el);
    messages.scrollTop = messages.scrollHeight;
  }

  form.addEventListener('submit', async e => {
    e.preventDefault();
    const text = input.value.trim();
    if (!text) return;

    input.value = '';
    addMessage('user', 'Aluno', text);
    addMessage('bot pending', '<%= missao.chat_funcionario || "Funcionario" %>', 'digitando...');
    const pending = messages.querySelector('.chat-message.pending');

    try {
      const res = await fetch('/mission/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ mission_id: missionId, message: text })
      });
      const data = await res.json();
      pending.remove();
      addMessage('bot', '<%= missao.chat_funcionario || "Funcionario" %>', data.reply || 'Nao consegui responder agora. Tente novamente.');
    } catch (err) {
      pending.remove();
      addMessage('bot', '<%= missao.chat_funcionario || "Funcionario" %>', 'Falha no simulador de chat. Continue a analise pelas perguntas da missao.');
    }
  });
})();
</script>
